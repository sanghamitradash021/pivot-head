     */
    getSankeyData(config?: Partial<ChartConfig>): SankeyChartData;
    /**
     * Get histogram data
     */
    getHistogramData(config?: Partial<ChartConfig>, numBins?: number): HistogramChartData;
    /**
     * Get combo chart data (bar + line)
     */
